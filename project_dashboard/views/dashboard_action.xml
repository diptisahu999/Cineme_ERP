<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Client Action ─────────────────────────────────────────────────────── -->
    <record id="action_project_dashboard" model="ir.actions.client">
        <field name="name">Project Dashboard</field>
        <field name="tag">project_dashboard_action</field>
    </record>

    <!-- ── Menu Item — Dashboard (sequence=1) ─────────────────────────────── -->
    <menuitem
        id="menu_project_dashboard"
        name="Dashboard"
        parent="project.menu_main_pm"
        action="action_project_dashboard"
        sequence="1"
        groups="project.group_project_user"
    />

    <!-- ── Security Groups for Department App ─────────────────────────────── -->
    <record id="module_category_department" model="ir.module.category">
        <field name="name">Department</field>
        <field name="parent_id" ref="base.module_category_human_resources"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_department_user" model="res.groups">
        <field name="name">User</field>
        <field name="category_id" ref="module_category_department"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>

    <record id="group_department_admin" model="res.groups">
        <field name="name">Administrator</field>
        <field name="category_id" ref="module_category_department"/>
        <field name="implied_ids" eval="[(4, ref('project_dashboard.group_department_user'))]"/>
        <field name="users" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
    </record>

    <!-- ── Menu Item — Department (sequence=-1, FIRST in Project app) ─────── -->
    <record id="action_project_department" model="ir.actions.act_window">
        <field name="name">Departments</field>
        <field name="res_model">hr.department</field>
        <field name="view_mode">kanban,list,form</field>
    </record>

    <menuitem
        id="menu_project_department"
        name="Department"
        action="action_project_department"
        web_icon="hr,static/description/icon.png"
        sequence="40"
    />
    <!-- Explicitly replace groups to ensure old groups (project_user) are removed -->
    <record id="menu_project_department" model="ir.ui.menu">
        <field name="groups_id" eval="[(6, 0, [ref('project_dashboard.group_department_user')])]"/>
    </record>

    <!-- ── Override Odoo's Projects menu to appear after Department ─────────── -->
    <record id="project.menu_projects" model="ir.ui.menu">
        <field name="sequence">10</field>
    </record>
    <!-- ── Make Kanban View the default for Project Tasks ──────────────────────── -->
    <record id="project.act_project_project_2_project_task_all" model="ir.actions.act_window">
        <field name="view_mode">kanban,list,form,calendar,pivot,graph,activity</field>
    </record>
    
    <!-- Reverting sequence to make Kanban the default over list view -->
    <record id="project.project_task_tree_action_view" model="ir.actions.act_window.view">
        <field name="sequence" eval="15"/>
    </record>

</odoo>