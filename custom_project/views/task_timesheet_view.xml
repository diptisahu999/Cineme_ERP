<odoo>
    <!-- List (Tree) View: add Timesheets column after date_deadline -->
    <record id="view_task_tree_timesheet_inherit" model="ir.ui.view">
        <field name="name">project.task.list.timesheet.inherit</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.project_task_view_tree_main_base"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='date_deadline']" position="after">
                <field name="timesheet_total" string="Timesheets" readonly="1" optional="show" widget="time_hour_uom"/>
            </xpath>
        </field>
    </record>

    <!-- Kanban View: add Timesheets hours on the card -->
    <record id="view_task_kanban_timesheet_inherit" model="ir.ui.view">
        <field name="name">project.task.kanban.timesheet.inherit</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_kanban"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='name']" position="after">
                <field name="timesheet_total" string="Timesheets" widget="time_hour_uom" readonly="1"/>
            </xpath>
            <xpath expr="//field[@name='remaining_hours'][@widget='timesheet_uom']" position="attributes">
                <attribute name="widget">time_hour_uom</attribute>
            </xpath>
            <xpath expr="//t[@name='allocated_hours']" position="inside">
                <div t-if="record.allocated_hours.raw_value &gt; 0 and record.allow_timesheets.raw_value" class="ms-1 align-self-center text-muted" title="Progress" groups="hr_timesheet.group_hr_timesheet_user">
                    <field name="progress" widget="percentage" options="{'digits': [1, 0]}"/>
                </div>
            </xpath>
        </field>
    </record>

    <!-- Form View: add Timesheets total after task_properties field -->
    <record id="view_task_form_timesheet_inherit" model="ir.ui.view">
        <field name="name">project.task.form.timesheet.inherit</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="project.view_task_form2"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='task_properties']" position="after">
                <group string="Timesheets">
                    <field name="timesheet_total" string="Total Hours" readonly="1" widget="time_hour_uom"/>
                </group>
            </xpath>
        </field>
    </record>

    <!-- Replace Employee column with User column in Timesheets tab -->
    <record id="view_task_form_user_timesheet" model="ir.ui.view">
        <field name="name">project.task.form.user.timesheet</field>
        <field name="model">project.task</field>
        <field name="inherit_id" ref="hr_timesheet.view_task_form2_inherited"/>
        <field name="arch" type="xml">
            <!-- Form View inside Timesheet Lines -->
            <xpath expr="//field[@name='timesheet_ids']/form//field[@name='employee_id']" position="attributes">
                <attribute name="invisible">1</attribute>
                <attribute name="required">0</attribute>
            </xpath>
            <xpath expr="//field[@name='timesheet_ids']/form//field[@name='user_id']" position="attributes">
                <attribute name="invisible">0</attribute>
                <attribute name="required">1</attribute>
                <attribute name="widget">many2one_avatar_user</attribute>
            </xpath>
            
            <!-- List View inside Timesheet Lines -->
            <xpath expr="//field[@name='timesheet_ids']/list//field[@name='employee_id']" position="attributes">
                <attribute name="column_invisible">1</attribute>
                <attribute name="required">0</attribute>
            </xpath>
            <xpath expr="//field[@name='timesheet_ids']/list//field[@name='user_id']" position="attributes">
                <attribute name="column_invisible">0</attribute>
                <attribute name="required">1</attribute>
                <attribute name="widget">many2one_avatar_user</attribute>
            </xpath>
        </field>
    </record>

    <!-- Hide the Employees app menu -->
    <record id="hr.menu_hr_root" model="ir.ui.menu">
        <field name="active" eval="False"/>
    </record>
</odoo>
